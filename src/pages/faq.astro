---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    category: 'Rechtliches & Sicherheit',
    items: [
      {
        q: 'Ist das legal?',
        a: 'Ja. KiezPower operiert als IT-Dienstleister gemäß § 42c EnWG — wir vermitteln Handelsverträge zwischen Privathaushalten, liefern selbst keinen Strom. Dein Netzbetreiber bleibt zuständig für Transport und Abrechnung. Gesetzliche Grundlage: EnWG § 42c i. V. m. dem Messstellenbetriebsgesetz (MsbG).',
      },
      {
        q: 'Was passiert, wenn mein Nachbar seinen Strom nicht zahlt?',
        a: 'Dein Risiko ist null. Käufer zahlen vorab in ihr KiezPower-Wallet ein — Strom wird nur gehandelt, wenn das Guthaben vorhanden ist. Deine Vergütung ist gesichert, bevor der Handel stattfindet. Vertragsschutz nach BGB § 305 ff., besichert durch Vorausbezahlung.',
      },
      {
        q: 'Bin ich noch an meinen Energieversorger gebunden?',
        a: 'Ja — und das ist gewollt. KiezPower ersetzt deinen Versorger nicht. Wenn kein Nachbar-Strom verfügbar ist, springt dein bestehender Tarif automatisch ein. Du brauchst nichts zu kündigen und hast jederzeit Versorgungssicherheit. Doppelter Schutz: Marktplatz + Grundversorgung.',
      },
    ],
  },
  {
    category: 'Allgemein',
    items: [
      {
        q: 'Was ist KiezPower?',
        a: 'KiezPower ist eine Plattform für automatisierten Peer-to-Peer Stromhandel zwischen Nachbarn. Haushalte mit Solaranlage verkaufen überschüssigen Strom direkt an Nachbarn in der Umgebung — vollautomatisch und zu fairen Preisen.',
      },
      {
        q: 'Wann startet KiezPower?',
        a: 'KiezPower befindet sich aktuell in der Entwicklung. Trag dich in unsere Warteliste ein, um als Erste*r informiert zu werden, sobald wir in deine Region kommen.',
      },
      {
        q: 'In welchen Regionen ist KiezPower verfügbar?',
        a: 'Zum Launch planen wir einen regionalen Pilotbetrieb in Deutschland. Über die Warteliste kannst du Interesse für deine Region signalisieren — das hilft uns bei der Planung des Rollouts.',
      },
    ],
  },
  {
    category: 'Für Produzenten (Solarstrom)',
    items: [
      {
        q: 'Was brauche ich, um meinen Solarstrom zu verkaufen?',
        a: 'Du brauchst eine PV-Anlage, einen modernen Smartmeter (mME) mit SML- oder IR-Schnittstelle sowie eine stabile Internetverbindung. Unterstützte Zählermodelle und Adapter werden auf der Plattform gelistet.',
      },
      {
        q: 'Zu welchem Preis wird mein Strom verkauft?',
        a: 'Du setzt selbst deinen Mindestpreis pro kWh. Als Richtwert gilt 15 ct/kWh — deutlich mehr als die typische Einspeisevergütung von etwa 8–10 ct/kWh. KiezPower matched dich automatisch mit Konsumenten, die dein Preislimit akzeptieren.',
      },
      {
        q: 'Wann und wie erhalte ich mein Geld?',
        a: 'Dein Guthaben wird in einem integrierten Wallet geführt. Auszahlungen sind per Banküberweisung möglich. Die genauen Auszahlungsintervalle werden vor dem Launch kommuniziert.',
      },
    ],
  },
  {
    category: 'Für Konsumenten',
    items: [
      {
        q: 'Wie viel kostet mich der Strom von KiezPower?',
        a: 'Du setzt dein persönliches Preislimit — KiezPower sucht Produzenten, die darunter oder genau daran anbieten. Im Schnitt zahlst du etwa 15 ct/kWh, zuzüglich gesetzlicher Netzentgelte. Das ist günstiger als die meisten Grundversorgertarife.',
      },
      {
        q: 'Brauche ich einen neuen Stromvertrag?',
        a: 'KiezPower ergänzt deinen bestehenden Netzbetreiber. Wenn gerade kein Nachbar-Strom verfügbar ist, beziehst du automatisch Netzstrom vom Fallback-Versorger. Du brauchst also keinen Vertrag zu kündigen.',
      },
      {
        q: 'Woher kommt mein Strom, wenn kein Nachbar gerade einspeist?',
        a: 'KiezPower arbeitet mit einem Fallback-Versorger zusammen. Der Wechsel zwischen lokalem P2P-Strom und Netzstrom erfolgt vollautomatisch — du merkst davon nichts.',
      },
    ],
  },
  {
    category: 'Technik & Datenschutz',
    items: [
      {
        q: 'Welche Smartmeter werden unterstützt?',
        a: 'Unterstützt werden Zähler mit SML-Protokoll (Optical Push) und IR-Schnittstelle, sowie gängige Adapter wie Tibber Pulse, Volkszähler und ähnliche. Eine vollständige Kompatibilitätsliste erscheint vor dem Launch.',
      },
      {
        q: 'Wie sicher sind meine Energiedaten?',
        a: 'Deine Zählerdaten werden verschlüsselt übertragen und ausschließlich zur Abrechnung genutzt. Wir geben keine Daten an Dritte weiter und sind DSGVO-konform. Jeder Handelsprozess wird mit einer eIDAS-konformen elektronischen Signatur abgesichert.',
      },
      {
        q: 'Was passiert mit meiner E-Mail-Adresse nach der Wartelisten-Anmeldung?',
        a: 'Deine E-Mail verwenden wir ausschließlich für Updates zu KiezPower. Du kannst dich jederzeit abmelden. Details findest du in unserer Datenschutzerklärung.',
      },
    ],
  },
];
---

<BaseLayout title="FAQ — KiezPower" description="Häufig gestellte Fragen zu KiezPower — dem P2P-Stromhandel zwischen Nachbarn.">
  <Nav />
  <main class="faq-page">
    <div class="container">
      <span class="section-tag">Fragen & Antworten</span>
      <h1>Häufig gestellte Fragen</h1>
      <p class="intro">
        Alles, was du über KiezPower wissen möchtest. Nicht dabei? Schreib uns: <a href="mailto:info@kiez-power.de">info@kiez-power.de</a>
      </p>

      {faqs.map((group) => (
        <div class="faq-group">
          <h2>{group.category}</h2>
          <div class="faq-list">
            {group.items.map((item) => (
              <details class="faq-item">
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .faq-page {
    padding: 8rem 0 5rem;
    min-height: 70vh;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
    color: var(--white);
  }

  .intro {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 3.5rem;
  }

  .intro a {
    color: var(--green);
    text-decoration: none;
  }

  .intro a:hover {
    text-decoration: underline;
  }

  .faq-group {
    margin-bottom: 3rem;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 1rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item:hover {
    border-color: rgba(148, 163, 184, 0.25);
  }

  .faq-item[open] {
    border-color: rgba(34, 197, 94, 0.25);
  }

  summary {
    padding: 1.1rem 1.5rem;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--white);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    user-select: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '+';
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--green);
    flex-shrink: 0;
    transition: transform 0.25s;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    padding: 0 1.5rem 1.25rem;
    color: var(--muted);
    line-height: 1.75;
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
</style>
