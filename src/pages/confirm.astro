---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'Anmeldung bestätigen — KiezPower';
const description = 'Bestätige deine Anmeldung für die KiezPower-Warteliste.';
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="confirm-page">
    <div class="container">
      <div class="confirm-card" id="confirm-card">
        <div class="loading-state" id="loading-state">
          <div class="spinner"></div>
          <h2>Bestätigung wird geprüft …</h2>
          <p>Einen Moment bitte.</p>
        </div>

        <div class="success-state" id="success-state" hidden>
          <div class="success-icon">✓</div>
          <h2>Vielen Dank!</h2>
          <p>Deine Anmeldung wurde erfolgreich bestätigt.</p>
          <p class="sub">Wir zählen dich jetzt in deiner PLZ mit. Du erhältst eine E-Mail, sobald KiezPower in deinem Kiez startet.</p>
          <a href="/" class="btn-primary">Zurück zur Startseite →</a>
        </div>

        <div class="error-state" id="error-state" hidden>
          <div class="error-icon">✗</div>
          <h2>Ups!</h2>
          <p id="error-message">Der Bestätigungslink ist ungültig oder abgelaufen.</p>
          <a href="/" class="btn-primary">Zurück zur Startseite →</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .confirm-page {
    padding: 8rem 0 5rem;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .confirm-card {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem;
    max-width: 480px;
    width: 100%;
    text-align: center;
  }

  .loading-state, .success-state, .error-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .loading-state[hidden], .success-state[hidden], .error-state[hidden] {
    display: none;
  }

  .spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--border);
    border-top-color: var(--green);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.12);
    border: 2px solid var(--green);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    color: var(--green);
    font-weight: 700;
    animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .error-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.12);
    border: 2px solid #ef4444;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    color: #ef4444;
    font-weight: 700;
  }

  @keyframes pop-in {
    from { transform: scale(0.92); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    margin: 0;
  }

  p {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .sub {
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .btn-primary {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.9rem 1.5rem;
    background: var(--green);
    color: var(--night);
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 200ms ease-out, transform 160ms ease-out;
  }

  .btn-primary:hover {
    background: var(--green-dim);
    transform: translateY(-1px);
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  const loadingEl = document.getElementById('loading-state');
  const successEl = document.getElementById('success-state');
  const errorEl   = document.getElementById('error-state');
  const errorMsg  = document.getElementById('error-message');

  async function confirmEntry() {
    const params = new URLSearchParams(window.location.search);
    const token  = params.get('token');

    if (!token) {
      showError('Kein Bestigungstoken gefunden.');
      return;
    }

    try {
      const { data, error } = await supabase
        .from('waitlist')
        .update({ confirmed: true })
        .eq('confirmation_token', token)
        .eq('confirmed', false)
        .select('id');

      if (error) {
        console.error('Confirmation error:', error);
        showError('Ein Fehler ist aufgetreten. Bitte versuche es später noch einmal.');
        return;
      }

      if (data && data.length > 0) {
        loadingEl.hidden = true;
        successEl.hidden = false;
      } else {
        showError('Der Bestätigungslink ist ungültig oder wurde bereits verwendet.');
      }
    } catch (err) {
      console.error('Confirmation failed:', err);
      showError('Ein Fehler ist aufgetreten. Bitte versuche es später noch einmal.');
    }
  }

  function showError(message) {
    loadingEl.hidden = true;
    errorMsg.textContent = message;
    errorEl.hidden = false;
  }

  // Run confirmation on page load
  confirmEntry();
</script>
