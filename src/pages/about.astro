---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppMockupBrowser from '../components/AppMockupBrowser.astro';

const title       = 'Christian Roessler · Senior Fullstack Engineer';
const description = 'Senior Fullstack Engineer für den deutschen Energiemarkt – Experte für §42c EnWG, Smart-Meter-Architektur, regulierungskonforme Systeme und KI-Integration.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <!-- Playfair Display -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />
    <!-- Tailwind CSS (CDN — no build integration in this project) -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "tertiary-fixed": "#dfe3e0",
              "inverse-on-surface": "#f1f1ef",
              "secondary": "#46645c",
              "on-tertiary-container": "#989c9a",
              "on-tertiary-fixed-variant": "#434846",
              "tertiary-container": "#2f3432",
              "on-background": "#1a1c1b",
              "on-surface": "#1a1c1b",
              "primary-container": "#2d3436",
              "surface-bright": "#faf9f7",
              "outline": "#747879",
              "on-primary": "#ffffff",
              "secondary-fixed": "#c8eadf",
              "on-error-container": "#93000a",
              "on-primary-fixed-variant": "#41484a",
              "surface-dim": "#dadad8",
              "on-surface-variant": "#434749",
              "primary": "#181f21",
              "tertiary-fixed-dim": "#c3c7c4",
              "surface-tint": "#586062",
              "on-tertiary": "#ffffff",
              "surface-container": "#efeeec",
              "inverse-surface": "#2f3130",
              "surface-container-low": "#f4f3f1",
              "on-primary-container": "#959c9f",
              "primary-fixed": "#dde4e6",
              "on-primary-fixed": "#161d1f",
              "surface": "#faf9f7",
              "surface-container-highest": "#e3e2e0",
              "on-secondary-fixed": "#01201a",
              "on-tertiary-fixed": "#181d1b",
              "inverse-primary": "#c1c8ca",
              "primary-fixed-dim": "#c1c8ca",
              "surface-variant": "#e3e2e0",
              "on-error": "#ffffff",
              "error": "#ba1a1a",
              "background": "#faf9f7",
              "surface-container-lowest": "#ffffff",
              "outline-variant": "#c3c7c8",
              "tertiary": "#1a1f1d",
              "secondary-fixed-dim": "#adcdc3",
              "error-container": "#ffdad6",
              "on-secondary-container": "#4c6a62",
              "secondary-container": "#c8eadf",
              "on-secondary": "#ffffff",
              "on-secondary-fixed-variant": "#2f4c45",
              "surface-container-high": "#e9e8e6",
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg: "0.25rem",
              xl: "0.5rem",
              full: "0.75rem",
            },
            spacing: {
              "stack-sm": "8px",
              "section-gap": "120px",
              "margin-mobile": "20px",
              "margin-desktop": "80px",
              "gutter": "24px",
              "stack-lg": "32px",
              "unit": "4px",
              "stack-md": "16px",
            },
            fontFamily: {
              "headline-sm": ["Playfair Display"],
              "quote": ["Playfair Display"],
              "label-caps": ["Inter"],
              "headline-md": ["Playfair Display"],
              "body-md": ["Inter"],
              "display-lg": ["Playfair Display"],
              "display-lg-mobile": ["Playfair Display"],
              "body-lg": ["Inter"],
            },
            fontSize: {
              "headline-sm": ["24px", { lineHeight: "1.4", fontWeight: "500" }],
              "quote": ["28px", { lineHeight: "1.5", fontWeight: "400" }],
              "label-caps": ["12px", { lineHeight: "1.0", letterSpacing: "0.1em", fontWeight: "600" }],
              "headline-md": ["32px", { lineHeight: "1.3", fontWeight: "500" }],
              "body-md": ["16px", { lineHeight: "1.6", fontWeight: "400" }],
              "display-lg": ["64px", { lineHeight: "1.1", letterSpacing: "-0.02em", fontWeight: "600" }],
              "display-lg-mobile": ["40px", { lineHeight: "1.2", letterSpacing: "-0.01em", fontWeight: "600" }],
              "body-lg": ["18px", { lineHeight: "1.6", letterSpacing: "0.01em", fontWeight: "400" }],
            },
          },
        },
      };
    </script>
  </Fragment>

  <!-- TopNavBar -->
  <header class="sticky top-0 z-50 w-full bg-background border-b border-outline-variant">
    <nav class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop max-w-[1440px] mx-auto h-20">
      <div class="font-headline-md text-headline-md text-primary italic">Christian Roessler</div>
      <div class="hidden md:flex gap-8">
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300" href="#about">About</a>
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300" href="#expertise">Expertise</a>
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300" href="#experience">Experience</a>
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300" href="#contact">Contact</a>
      </div>
      <a class="hidden md:inline-flex items-center justify-center bg-primary text-on-primary font-label-caps text-label-caps px-6 py-3 rounded hover:bg-primary-container transition-colors" href="#contact">
        Connect
      </a>
      <button class="md:hidden text-primary" id="mobile-menu-btn" aria-label="Menü öffnen">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </nav>
  </header>

  <main>
    <!-- Hero / About -->
    <section class="relative pt-section-gap pb-section-gap px-margin-mobile md:px-margin-desktop max-w-[1440px] mx-auto" id="about">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-center">
        <div class="md:col-span-7 space-y-stack-lg z-10">
          <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary">
            Christian Roessler
          </h1>
          <p class="font-quote text-quote text-on-surface-variant max-w-2xl">
            Senior Fullstack Engineer an der Schnittstelle von Software-Architektur und Energieregulierung.
          </p>
          <p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl">
            Konzeption und Entwicklung komplexer, regulierungskonformer Systeme für den modernen Energiemarkt.
          </p>
        </div>
        <div class="md:col-span-5 relative mt-stack-lg md:mt-0">
          <div class="aspect-[4/5] overflow-hidden rounded bg-surface-container">
            <img
              src="/christian-roessler.jpg"
              alt="Christian Roessler Portrait"
              class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700"
              loading="eager"
              width="600"
              height="750"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 w-48 h-48 bg-surface-container-highest -z-10 rounded"></div>
        </div>
      </div>
    </section>

    <!-- Profil -->
    <section class="py-section-gap px-margin-mobile md:px-margin-desktop bg-surface-bright border-y border-outline-variant">
      <div class="max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-gutter">
        <div class="md:col-span-4">
          <h2 class="font-headline-md text-headline-md text-primary mb-stack-md">Profil</h2>
          <div class="w-12 h-[1px] bg-primary"></div>
        </div>
        <div class="md:col-span-8 space-y-stack-md">
          <p class="font-body-lg text-body-lg text-on-surface leading-relaxed">
            Mit über 13 Jahren Erfahrung in der Softwareentwicklung verbinde ich tiefe technische Expertise mit einem detaillierten Verständnis der Energieregulierung. Meine Arbeit konzentriert sich auf die Übersetzung komplexer rechtlicher Anforderungen in robuste, skalierbare Software-Architekturen.
          </p>
          <p class="font-body-lg text-body-lg text-on-surface leading-relaxed">
            Diese Doppelqualifikation ermöglicht es mir, nicht nur Code zu schreiben, sondern Systeme zu entwerfen, die den strengen Vorgaben des europäischen und deutschen Energiemarktes entsprechen, ohne dabei an technologischer Agilität einzubüßen.
          </p>
        </div>
      </div>
    </section>

    <!-- Expertise -->
    <section class="py-section-gap px-margin-mobile md:px-margin-desktop max-w-[1440px] mx-auto" id="expertise">
      <h2 class="font-headline-md text-headline-md text-primary mb-stack-lg text-center">Expertise</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
        <!-- Tech Stack -->
        <div class="bg-surface p-stack-lg border border-outline-variant rounded hover:bg-surface-container-low transition-colors duration-300">
          <div class="flex items-center gap-4 mb-stack-md">
            <span class="material-symbols-outlined text-secondary text-3xl">code</span>
            <h3 class="font-headline-sm text-headline-sm text-primary">Software-Architektur</h3>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-stack-lg">
            Moderne, performante Stacks für datenintensive Anwendungen.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">SvelteKit</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">ElysiaJS/Bun</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">PostgreSQL</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">TimescaleDB</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">Drizzle</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">Redis</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">AI/Automation (Claude API, RAG, n8n)</span>
          </div>
        </div>

        <!-- Domain -->
        <div class="bg-surface p-stack-lg border border-outline-variant rounded hover:bg-surface-container-low transition-colors duration-300">
          <div class="flex items-center gap-4 mb-stack-md">
            <span class="material-symbols-outlined text-secondary text-3xl">gavel</span>
            <h3 class="font-headline-sm text-headline-sm text-primary">Energie-Domäne</h3>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-stack-lg">
            Übersetzung von Regulatorik in Systemdesign.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">§ 42c EnWG</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">eIDAS</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">Marktkommunikation</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">Bilanzkreismanagement</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">EEG-Reform</span>
            <span class="px-3 py-1 bg-secondary/10 text-secondary font-label-caps text-label-caps rounded">DSGVO-konforme Architektur</span>
          </div>
        </div>
      </div>
    </section>

    <!-- KiezPower Dashboard Showcase -->
    <section class="py-section-gap px-margin-mobile md:px-margin-desktop bg-surface-container-low" id="showcase">
      <div class="max-w-[1440px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-center mb-stack-lg">
          <!-- Copy -->
          <div class="md:col-span-5 space-y-stack-md">
            <div class="font-label-caps text-label-caps text-secondary tracking-widest uppercase">Plattform-Showcase</div>
            <h2 class="font-headline-md text-headline-md text-primary">KiezPower Dashboard</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant">
              Konzeption und Implementierung einer intuitiven Schnittstelle für komplexe regulatorische Anforderungen. Dieses Dashboard übersetzt Smart-Meter-Daten gemäß § 42c EnWG in Echtzeit-Insights.
            </p>
            <p class="font-body-md text-body-md text-on-surface-variant">
              Die Herausforderung lag in der Brückenbildung zwischen technischer Präzision (Bilanzkreismanagement) und einer nutzerzentrierten Experience für lokale Energiegemeinschaften.
            </p>
            <div class="pt-stack-md">
              <a
                class="inline-flex items-center gap-2 font-label-caps text-label-caps text-primary hover:text-secondary transition-colors border-b border-primary hover:border-secondary pb-1"
                href="https://kiez-power.de"
                rel="noopener noreferrer"
                target="_blank"
              >
                Live-Plattform ansehen <span class="material-symbols-outlined text-sm">arrow_outward</span>
              </a>
            </div>
          </div>

          <!-- Dashboard Mockup -->
           <div class="md:col-span-7 mt-stack-lg md:mt-0">
             <AppMockupBrowser />
           </div>
        </div>
      </div>
    </section>

    <!-- Kontakt -->
    <section class="py-section-gap px-margin-mobile md:px-margin-desktop max-w-[1440px] mx-auto text-center" id="contact">
      <h2 class="font-headline-md text-headline-md text-primary mb-stack-md">Lassen Sie uns ins Gespräch kommen</h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto mb-stack-lg">
        Für Anfragen zu Beratung, Architektur-Reviews oder strategischen Projekten im Energiesektor.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-stack-md">
        <a
          class="inline-flex items-center justify-center bg-primary text-on-primary font-label-caps text-label-caps px-8 py-4 rounded hover:bg-primary-container transition-colors min-w-[200px]"
          href="mailto:christian.roessler@cmdscale.com"
        >
          Email Senden
        </a>
        <a
          class="inline-flex items-center justify-center bg-transparent border border-outline text-primary font-label-caps text-label-caps px-8 py-4 rounded hover:bg-surface-container-low transition-colors min-w-[200px]"
          href="https://linkedin.com/in/christianroessler"
          rel="noopener noreferrer"
          target="_blank"
        >
          LinkedIn Profil
        </a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-surface-container dark:bg-primary-container border-t border-outline-variant dark:border-outline">
    <div class="flex flex-col md:flex-row justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-stack-lg max-w-[1440px] mx-auto gap-stack-md">
      <div class="font-headline-sm text-headline-sm text-primary dark:text-on-primary">
        Christian Roessler
      </div>
      <div class="flex flex-wrap gap-4 justify-center">
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="https://linkedin.com/in/christianroessler" rel="noopener noreferrer" target="_blank">LinkedIn</a>
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="mailto:christian.roessler@cmdscale.com">Email</a>
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="/impressum">Imprint</a>
        <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="/datenschutz">Privacy</a>
      </div>
      <div class="font-body-md text-body-md text-on-surface dark:text-on-primary-container">
        &copy; 2024 Christian Roessler. All rights reserved.
      </div>
    </div>
  </footer>
</BaseLayout>

<style is:global>
  /* Page-level overrides for this design system */
  body {
    background-color: #faf9f7;
    color: #1a1c1b;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  /* Highlight selection uses primary-container */
  ::selection {
    background-color: #2d3436;
    color: #ffffff;
  }
</style>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const nav = document.querySelector('header nav > div.hidden');
    if (!nav) return;
    nav.classList.toggle('hidden');
    nav.classList.toggle('flex');
    nav.classList.toggle('flex-col');
    nav.classList.toggle('absolute');
    nav.classList.toggle('top-20');
    nav.classList.toggle('left-0');
    nav.classList.toggle('w-full');
    nav.classList.toggle('bg-background');
    nav.classList.toggle('px-margin-mobile');
    nav.classList.toggle('py-stack-md');
    nav.classList.toggle('border-b');
    nav.classList.toggle('border-outline-variant');
  });
</script>
