---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'Für Solarteure — KiezPower';
const description = 'Biete deinen Kunden einen einfachen Zugang zu lokalem Stromsharing. Steigere deine Bindung und werde zum Vorreiter der Energiewende.';
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="solarteur-page">
    <div class="container">

      <span class="section-tag">Für Solarteure</span>
      <h1>Stärke dein Angebot mit KiezPower</h1>
      <p class="lead">
        Deine Kunden kaufen eine PV-Anlage — aber was passiert mit dem Überschuss?
        Mit KiezPower können sie ihn direkt an Nachbarn verkaufen. Wir machen's möglich,
        du machst's bekannt.
      </p>

      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3>Mehrwert für Kunden</h3>
          <p>Deine Kunden erhalten einen konkreten Nutzen aus ihrer PV-Anlage — über den Eigenverbrauch hinaus.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3>Lokale Community</h3>
          <p>Starke Nachbarschaftsbindung durch lokalen Stromhandel — deine Kunden werden Teil einer Energiegemeinschaft.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
            </svg>
          </div>
          <h3>Wettbewerbsvorteil</h3>
          <p>Hebe dich von anderen Installatoren ab — biete deinen Kunden eine echte Stromsharing-Lösung dazu.</p>
        </div>
      </div>

      <div class="how-it-works">
        <h2>So funktioniert's</h2>
        <div class="steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-content">
              <h4>Link generieren</h4>
              <p>Erstelle deinen persönlichen Empfehlungslink mit deinem Installateur-Code.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-content">
              <h4>Mit Kunden teilen</h4>
              <p>Teile den Link bei Beratungsgesprächen, auf deiner Website oder per QR-Code.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-content">
              <h4>Kunden melden sich an</h4>
              <p>Deine Kunden tragen sich mit E-Mail und PLZ ein — du wirst als Empfehlungsgeber hinterlegt.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="referral-section">
        <h2>Dein Empfehlungslink</h2>
        <p>Gib deinen Installateur-Code ein, um deinen persönlichen Link zu generieren:</p>
        
        <div class="code-input-group">
          <input 
            type="text" 
            id="installer-code" 
            placeholder="Dein Code (z.B. sonnendach)" 
            maxlength="20"
            pattern="[a-zA-Z0-9_-]+"
          />
          <button id="generate-link" class="btn-secondary">Link generieren</button>
        </div>

        <div class="referral-link-box" id="referral-link-box" hidden>
          <label>Dein Empfehlungslink:</label>
          <div class="link-row">
            <code id="referral-link">–</code>
            <button id="copy-link" class="btn-copy" title="Link kopieren">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
              </svg>
            </button>
          </div>
          <p class="link-hint">Teile diesen Link mit deinen Kunden — sie werden direkt zur Warteliste weitergeleitet.</p>
        </div>
      </div>

      <div class="cta-box">
        <h2>Bereit loszulegen?</h2>
        <p>
          Trag dich jetzt ein und werde einer der ersten KiezPower-Partner in deiner Region.
        </p>
        <a href="/#warteliste" class="btn-primary">Jetzt partner werden →</a>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .solarteur-page {
    padding: 8rem 0 5rem;
    min-height: 70vh;
  }

  .section-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    background: rgba(34, 197, 94, 0.1);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
    color: var(--white);
  }

  .lead {
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .benefit-card {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }

  .benefit-icon {
    color: var(--green);
    margin-bottom: 1rem;
  }

  .benefit-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .benefit-card p {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }

  .how-it-works {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
  }

  .how-it-works h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 2rem;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid var(--green);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--green);
    flex-shrink: 0;
  }

  .step-content h4 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.25rem;
  }

  .step-content p {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }

  .referral-section {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    margin-bottom: 4rem;
  }

  .referral-section h2 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .referral-section > p {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .code-input-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .code-input-group input {
    flex: 1;
    background: var(--night);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 200ms ease-out;
  }

  .code-input-group input::placeholder { color: rgba(148, 163, 184, 0.4); }
  .code-input-group input:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
  }

  .btn-secondary {
    background: transparent;
    color: var(--green);
    border: 1px solid var(--green);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    transition: background 150ms ease-out;
    white-space: nowrap;
  }

  .btn-secondary:hover {
    background: rgba(34, 197, 94, 0.1);
  }

  .referral-link-box {
    background: var(--night);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
  }

  .referral-link-box[hidden] { display: none; }

  .referral-link-box label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .link-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .link-row code {
    flex: 1;
    font-family: monospace;
    font-size: 0.875rem;
    color: var(--green);
    background: var(--night-mid);
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius-sm);
    word-break: break-all;
  }

  .btn-copy {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.6rem;
    cursor: pointer;
    color: var(--muted);
    transition: color 150ms ease-out, border-color 150ms ease-out;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-copy:hover {
    color: var(--white);
    border-color: var(--white);
  }

  .link-hint {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  .cta-box {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    text-align: center;
  }

  .cta-box h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--white);
  }

  .cta-box p {
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.9rem 1.5rem;
    background: var(--green);
    color: var(--night);
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 200ms ease-out, transform 160ms ease-out;
  }

  .btn-primary:hover {
    background: var(--green-dim);
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .code-input-group {
      flex-direction: column;
    }
  }
</style>

<script>
  const generateBtn = document.getElementById('generate-link');
  const codeInput = document.getElementById('installer-code') as HTMLInputElement;
  const linkBox = document.getElementById('referral-link-box');
  const linkDisplay = document.getElementById('referral-link');
  const copyBtn = document.getElementById('copy-link');

  generateBtn?.addEventListener('click', () => {
    const code = codeInput.value.trim();
    if (!code) return;

    // Validate code: alphanumeric, hyphens, underscores only
    if (!/^[a-zA-Z0-9_-]+$/.test(code)) {
      codeInput.style.borderColor = '#ef4444';
      return;
    }

    codeInput.style.borderColor = '';
    const url = `${window.location.origin}/?ref=${encodeURIComponent(code)}`;
    if (linkDisplay) linkDisplay.textContent = url;
    if (linkBox) linkBox.hidden = false;
  });

  copyBtn?.addEventListener('click', async () => {
    const link = linkDisplay?.textContent;
    if (!link) return;

    try {
      await navigator.clipboard.writeText(link);
      copyBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      `;
      setTimeout(() => {
        copyBtn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
          </svg>
        `;
      }, 2000);
    } catch {
      console.error('Failed to copy');
    }
  });
</script>
