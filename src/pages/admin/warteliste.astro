---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout>
  <Fragment slot="head">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </Fragment>

  <div class="min-h-screen bg-gray-50">
    <!-- Login Screen -->
    <div id="login-screen" class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-md w-full">
        <div class="text-center mb-6">
          <h1 class="text-2xl font-bold text-gray-900">KiezPower Admin</h1>
          <p class="text-gray-500 mt-1">Wartelisten-Dashboard</p>
        </div>
        <form id="login-form">
          <div class="mb-4">
            <label for="login-email" class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
            <input
              id="login-email"
              type="email"
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              placeholder="info@kiez-power.de"
            />
          </div>
          <button type="submit" class="w-full bg-blue-900 text-white font-semibold py-2.5 px-4 rounded-lg hover:bg-blue-800 transition-colors">
            Magic Link senden
          </button>
          <p id="login-error" class="text-red-600 text-sm mt-2 hidden"></p>
          <p id="login-success" class="text-green-600 text-sm mt-2 hidden">Pruefe dein E-Mail-Postfach.</p>
        </form>
        <button id="logout-btn" class="hidden mt-4 w-full text-sm text-gray-500 hover:text-gray-700 underline" type="button">Abmelden</button>
      </div>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="hidden">
      <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
          <div>
            <h1 class="text-xl font-bold text-gray-900">Warteliste</h1>
            <p class="text-sm text-gray-500">
              Ziel: <strong id="goal-display">100 Anmeldungen</strong>
              &middot;
              <span id="progress-display">0 / 100</span>
            </p>
          </div>
          <div class="flex items-center gap-4">
            <span id="ceo-email-display" class="text-sm text-gray-500"></span>
            <button id="dashboard-logout" class="text-sm text-red-600 hover:text-red-800 underline" type="button">Abmelden</button>
          </div>
        </div>
      </header>

      <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <p class="text-sm text-gray-500 uppercase tracking-wider font-medium">Gesamt</p>
            <p id="stat-total" class="text-3xl font-bold text-gray-900 mt-1">-</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <p class="text-sm text-gray-500 uppercase tracking-wider font-medium">Konsumenten</p>
            <p id="stat-konsument" class="text-3xl font-bold text-gray-900 mt-1">-</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <p class="text-sm text-gray-500 uppercase tracking-wider font-medium">Produzenten</p>
            <p id="stat-produzent" class="text-3xl font-bold text-gray-900 mt-1">-</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <p class="text-sm text-gray-500 uppercase tracking-wider font-medium">Beides</p>
            <p id="stat-beides" class="text-3xl font-bold text-gray-900 mt-1">-</p>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-4 mb-6 flex flex-wrap gap-4 items-end">
          <div>
            <label for="filter-plz" class="block text-xs font-medium text-gray-600 mb-1 uppercase tracking-wider">PLZ</label>
            <input id="filter-plz" type="text" class="w-32 px-3 py-1.5 border border-gray-300 rounded text-sm" placeholder="z.B. 19053" maxlength="5" />
          </div>
          <div>
            <label for="filter-role" class="block text-xs font-medium text-gray-600 mb-1 uppercase tracking-wider">Rolle</label>
            <select id="filter-role" class="px-3 py-1.5 border border-gray-300 rounded text-sm">
              <option value="">Alle</option>
              <option value="Konsument">Konsument</option>
              <option value="Produzent">Produzent</option>
              <option value="Beides">Beides</option>
            </select>
          </div>
          <div>
            <label for="filter-operator" class="block text-xs font-medium text-gray-600 mb-1 uppercase tracking-wider">Netzbetreiber</label>
            <input id="filter-operator" type="text" class="w-48 px-3 py-1.5 border border-gray-300 rounded text-sm" placeholder="z.B. E.DIS" />
          </div>
          <div>
            <label for="filter-source" class="block text-xs font-medium text-gray-600 mb-1 uppercase tracking-wider">Quelle</label>
            <select id="filter-source" class="px-3 py-1.5 border border-gray-300 rounded text-sm">
              <option value="">Alle</option>
              <option value="web">Web</option>
              <option value="b2b">B2B</option>
              <option value="import">Import</option>
            </select>
          </div>
          <button id="btn-csv" class="bg-green-700 text-white text-sm font-medium px-4 py-1.5 rounded hover:bg-green-600 transition-colors">
            CSV exportieren
          </button>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="text-left px-4 py-3 font-semibold text-gray-600">E-Mail</th>
                  <th class="text-left px-4 py-3 font-semibold text-gray-600">PLZ</th>
                  <th class="text-left px-4 py-3 font-semibold text-gray-600">Rolle</th>
                  <th class="text-left px-4 py-3 font-semibold text-gray-600">Netzbetreiber</th>
                  <th class="text-left px-4 py-3 font-semibold text-gray-600">Quelle</th>
                  <th class="text-left px-4 py-3 font-semibold text-gray-600">Datum</th>
                </tr>
              </thead>
              <tbody id="waitlist-rows">
                <tr><td colspan="6" class="text-center px-4 py-8 text-gray-400">Lade Daten...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="border-t border-gray-200 px-4 py-3 flex items-center justify-between bg-gray-50">
            <span id="table-count" class="text-sm text-gray-500">0 Eintraege</span>
            <div class="flex gap-2">
              <button id="btn-prev" class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40" disabled>&larr; Zuerueck</button>
              <button id="btn-next" class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">Weiter &rarr;</button>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
    auth: { persistSession: true, storageKey: 'kiezpower-admin-auth' },
  });

  const loginScreen = document.getElementById('login-screen');
  const dashboard   = document.getElementById('dashboard');
  const loginForm   = document.getElementById('login-form');
  const loginEmail  = document.getElementById('login-email');
  const loginError  = document.getElementById('login-error');
  const loginSuccess = document.getElementById('login-success');
  const logoutBtn   = document.getElementById('logout-btn');
  const dashLogout  = document.getElementById('dashboard-logout');
  const ceoEmail    = document.getElementById('ceo-email-display');
  const progress    = document.getElementById('progress-display');

  const statTotal  = document.getElementById('stat-total');
  const statKon    = document.getElementById('stat-konsument');
  const statProd   = document.getElementById('stat-produzent');
  const statBeides = document.getElementById('stat-beides');
  const waitlistRows = document.getElementById('waitlist-rows');
  const tableCount   = document.getElementById('table-count');

  const filterPlz    = document.getElementById('filter-plz');
  const filterRole   = document.getElementById('filter-role');
  const filterOp     = document.getElementById('filter-operator');
  const filterSource = document.getElementById('filter-source');
  const btnCsv       = document.getElementById('btn-csv');
  const btnPrev      = document.getElementById('btn-prev');
  const btnNext      = document.getElementById('btn-next');

  const PAGE_SIZE = 50;
  let currentPage = 0;
  let allData = [];

  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) showDashboard(session.user.email);
  });

  supabase.auth.onAuthStateChange((event, session) => {
    if (event === 'SIGNED_IN' && session) showDashboard(session.user.email);
    if (event === 'SIGNED_OUT') showLogin();
  });

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.hidden = true;
    loginSuccess.hidden = true;
    const email = loginEmail.value.trim();
    if (!email) return;
    const { error } = await supabase.auth.signInWithOtp({ email });
    if (error) { loginError.textContent = error.message; loginError.hidden = false; return; }
    loginSuccess.hidden = false;
    loginForm.querySelector('button').disabled = true;
    loginForm.querySelector('button').textContent = 'E-Mail gesendet...';
  });

  logoutBtn.addEventListener('click', () => supabase.auth.signOut());
  dashLogout.addEventListener('click', () => supabase.auth.signOut());

  function showLogin() { loginScreen.hidden = false; dashboard.classList.add('hidden'); }
  function showDashboard(email) {
    loginScreen.classList.add('hidden');
    dashboard.classList.remove('hidden');
    ceoEmail.textContent = email;
    loadData();
  }

  function hideEmail(email) {
    if (!email) return '-';
    const [local, domain] = email.split('@');
    if (local.length <= 2) return local[0] + '***@' + domain;
    return local.slice(0, 2) + '***@' + domain;
  }

  function formatDate(ts) {
    return new Date(ts).toLocaleDateString('de-DE', {
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    });
  }

  async function loadData() {
    const { data, error } = await supabase
      .from('waitlist')
      .select('*')
      .order('created_at', { ascending: false });
    if (error) {
      waitlistRows.innerHTML = '<tr><td colspan="6" class="text-center px-4 py-8 text-red-600">Fehler: ' + error.message + '</td></tr>';
      return;
    }
    allData = data || [];
    applyFilters();
  }

  function applyFilters() {
    const plz = filterPlz.value.trim();
    const role = filterRole.value;
    const op = filterOp.value.trim().toLowerCase();
    const src = filterSource.value;
    let filtered = allData;
    if (plz) filtered = filtered.filter(r => r.plz.startsWith(plz));
    if (role) filtered = filtered.filter(r => r.role === role);
    if (op) filtered = filtered.filter(r => r.operator && r.operator.toLowerCase().includes(op));
    if (src) filtered = filtered.filter(r => r.source === src);
    renderStats(filtered);
    renderTable(filtered);
  }

  function renderStats(data) {
    const total = data.length;
    statTotal.textContent = total;
    statKon.textContent  = data.filter(r => r.role === 'Konsument').length;
    statProd.textContent = data.filter(r => r.role === 'Produzent').length;
    statBeides.textContent = data.filter(r => r.role === 'Beides').length;
    progress.textContent = total + ' / 100';
  }

  function renderTable(data) {
    const totalPages = Math.ceil(data.length / PAGE_SIZE);
    const start = currentPage * PAGE_SIZE;
    const page = data.slice(start, start + PAGE_SIZE);
    tableCount.textContent = data.length + ' Eintraege (Seite ' + (currentPage + 1) + ' von ' + Math.max(totalPages, 1) + ')';
    btnPrev.disabled = currentPage === 0;
    btnNext.disabled = start + PAGE_SIZE >= data.length;
    if (page.length === 0) {
      waitlistRows.innerHTML = '<tr><td colspan="6" class="text-center px-4 py-8 text-gray-400">Keine Eintraege gefunden</td></tr>';
      return;
    }
    waitlistRows.innerHTML = page.map(r => {
      const roleClass = r.role === 'Produzent' ? 'bg-amber-100 text-amber-800'
        : r.role === 'Beides' ? 'bg-blue-100 text-blue-800'
        : 'bg-gray-100 text-gray-800';
      return '<tr class="border-b border-gray-100 hover:bg-gray-50">'
        + '<td class="px-4 py-3 text-gray-800">' + hideEmail(r.email) + '</td>'
        + '<td class="px-4 py-3 font-mono text-gray-900">' + r.plz + '</td>'
        + '<td class="px-4 py-3"><span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full ' + roleClass + '">' + r.role + '</span></td>'
        + '<td class="px-4 py-3 text-gray-600 text-sm max-w-[200px] truncate" title="' + (r.operator || '') + '">' + (r.operator || '-') + '</td>'
        + '<td class="px-4 py-3 text-gray-500 text-xs uppercase">' + (r.source || 'web') + '</td>'
        + '<td class="px-4 py-3 text-gray-500 whitespace-nowrap">' + formatDate(r.created_at) + '</td>'
        + '</tr>';
    }).join('');
  }

  filterPlz.addEventListener('input', () => { currentPage = 0; applyFilters(); });
  filterRole.addEventListener('change', () => { currentPage = 0; applyFilters(); });
  filterOp.addEventListener('input', () => { currentPage = 0; applyFilters(); });
  filterSource.addEventListener('change', () => { currentPage = 0; applyFilters(); });
  btnPrev.addEventListener('click', () => { if (currentPage > 0) { currentPage--; applyFilters(); } });
  btnNext.addEventListener('click', () => { currentPage++; applyFilters(); });

  btnCsv.addEventListener('click', () => {
    const headers = ['E-Mail', 'PLZ', 'Rolle', 'Netzbetreiber', 'Quelle', 'Datum'];
    const rows = allData.map(r => [
      r.email, r.plz, r.role, r.operator || '', r.source || 'web',
      new Date(r.created_at).toISOString(),
    ]);
    const csv = [headers, ...rows].map(row =>
      row.map(c => '"' + String(c).replace(/"/g, '""') + '"').join(',')
    ).join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'kiezpower-warteliste-' + new Date().toISOString().slice(0, 10) + '.csv';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
