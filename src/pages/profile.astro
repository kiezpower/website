---
import BaseLayout from '../layouts/BaseLayout.astro';

const title       = 'Christian Roessler · Senior Fullstack Engineer';
const description = 'Senior Fullstack Engineer für den deutschen Energiemarkt – spezialisiert auf §42c EnWG, Smart Metering, KI-Integration und skalierbare Fullstack-Architekturen.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <!-- Playfair Display -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
    <!-- Tailwind CSS (CDN — no build integration in this project) -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-primary": "#ffffff",
              "tertiary-container": "#3d4143",
              "secondary-fixed": "#ffdbca",
              "secondary": "#9b4500",
              "on-primary-fixed": "#00164e",
              "on-primary-container": "#90a8ff",
              "secondary-container": "#fd8a42",
              "inverse-on-surface": "#eef0ff",
              "on-secondary-container": "#682c00",
              "on-secondary": "#ffffff",
              "on-error-container": "#93000a",
              "surface-container-highest": "#dae2fd",
              "surface-container-high": "#e2e7ff",
              "on-background": "#131b2e",
              "error-container": "#ffdad6",
              "on-tertiary-container": "#aaadaf",
              "on-secondary-fixed": "#331200",
              "surface-dim": "#d2d9f4",
              "surface": "#faf8ff",
              "on-secondary-fixed-variant": "#763300",
              "surface-container-low": "#f2f3ff",
              "on-error": "#ffffff",
              "primary-fixed": "#dce1ff",
              "inverse-primary": "#b6c4ff",
              "on-primary-fixed-variant": "#264191",
              "tertiary-fixed-dim": "#c4c7c9",
              "surface-bright": "#faf8ff",
              "tertiary-fixed": "#e0e3e5",
              "outline-variant": "#c5c5d3",
              "muted-text": "#475569",
              "inverse-surface": "#283044",
              "on-surface-variant": "#444651",
              "surface-card": "#FFFFFF",
              "secondary-fixed-dim": "#ffb68e",
              "surface-variant": "#dae2fd",
              "outline": "#757682",
              "on-tertiary-fixed-variant": "#444749",
              "background": "#faf8ff",
              "ink-text": "#0F172A",
              "on-surface": "#131b2e",
              "primary-container": "#1e3a8a",
              "tertiary": "#272b2d",
              "on-tertiary": "#ffffff",
              "surface-container-lowest": "#ffffff",
              "primary-fixed-dim": "#b6c4ff",
              "primary": "#00236f",
              "surface-tint": "#4059aa",
              "surface-container": "#eaedff",
              "on-tertiary-fixed": "#191c1e",
              "border-subtle": "#CBD5E1",
              "error": "#ba1a1a",
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
            spacing: {
              "stack-sm": "1rem",
              "gutter": "2rem",
              "stack-lg": "4rem",
              "margin-mobile": "1rem",
              "stack-md": "2rem",
              "container-max": "1200px",
            },
            fontFamily: {
              "headline-md": ["Playfair Display"],
              "headline-lg-mobile": ["Playfair Display"],
              "headline-lg": ["Playfair Display"],
              "headline-xl": ["Playfair Display"],
              "body-lg": ["Inter"],
              "body-md": ["Inter"],
              "label-sm": ["Inter"],
            },
            fontSize: {
              "headline-md": ["30px", { lineHeight: "1.3", fontWeight: "600" }],
              "headline-lg-mobile": ["32px", { lineHeight: "1.2", fontWeight: "700" }],
              "headline-lg": ["48px", { lineHeight: "1.2", fontWeight: "700" }],
              "headline-xl": ["60px", { lineHeight: "1.1", letterSpacing: "-0.02em", fontWeight: "700" }],
              "body-lg": ["18px", { lineHeight: "1.6", fontWeight: "400" }],
              "body-md": ["16px", { lineHeight: "1.5", fontWeight: "400" }],
              "label-sm": ["14px", { lineHeight: "1", letterSpacing: "0.05em", fontWeight: "600" }],
            },
          },
        },
      };
    </script>
  </Fragment>

  <!-- Navigation -->
  <header class="bg-surface dark:bg-on-background border-b border-outline-variant dark:border-tertiary-container sticky top-0 z-50 transition-colors duration-300 w-full">
    <div class="flex justify-between items-center px-8 py-6 max-w-container-max mx-auto w-full">
      <div class="font-headline-md text-headline-md font-bold text-ink-text dark:text-surface-bright">
        Christian Roessler
      </div>
      <nav class="hidden md:flex items-center space-x-8 font-body-md text-body-md uppercase tracking-wider">
        <a class="text-primary dark:text-primary-fixed font-bold border-b-2 border-secondary-container pb-1 hover:text-primary dark:hover:text-primary-fixed-dim transition-colors duration-300 opacity-80" href="#expertise">Expertise</a>
        <a class="text-muted-text dark:text-on-tertiary-container hover:text-primary dark:hover:text-primary-fixed-dim transition-colors duration-300" href="#work">Work</a>
        <a class="text-muted-text dark:text-on-tertiary-container hover:text-primary dark:hover:text-primary-fixed-dim transition-colors duration-300" href="#philosophy">Philosophy</a>
        <a class="text-muted-text dark:text-on-tertiary-container hover:text-primary dark:hover:text-primary-fixed-dim transition-colors duration-300" href="#process">Process</a>
      </nav>
      <a class="hidden md:inline-flex items-center justify-center bg-navy text-white font-label-sm text-label-sm uppercase px-6 py-3 rounded hover:bg-primary transition-colors duration-300" href="#contact">
        Get in Touch
      </a>
      <button class="md:hidden text-ink-text" id="mobile-menu-btn" aria-label="Menü öffnen">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="max-w-container-max mx-auto px-4 md:px-8 py-16 md:py-stack-lg grid grid-cols-1 md:grid-cols-12 gap-gutter items-center">
    <!-- Left: Copy -->
    <div class="md:col-span-7 flex flex-col items-start space-y-6">
      <div class="inline-flex items-center space-x-2 bg-surface-container px-3 py-1.5 rounded-full border border-border-subtle">
        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
        <span class="font-label-sm text-label-sm text-muted-text">Offen für Festanstellung</span>
      </div>
      <h1 class="font-headline-lg-mobile md:font-headline-xl text-headline-lg-mobile md:text-headline-xl text-ink-text">
        Software, die <br class="hidden md:block" />wirklich <span class="text-primary-container italic">funktioniert.</span>
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
        Als Senior Fullstack Engineer entwickle ich robuste, hochperformante Systeme. Mein Fokus liegt auf messbarer Qualität, sauberer Architektur und Lösungen, die komplexe Geschäftsprozesse, insbesondere im Energiesektor, effizient digitalisieren.
      </p>
      <div class="flex flex-col sm:flex-row items-center space-y-4 sm:space-y-0 sm:space-x-4 pt-4 w-full sm:w-auto">
        <a class="w-full sm:w-auto text-center bg-navy text-white font-label-sm text-label-sm uppercase px-8 py-4 rounded hover:bg-primary transition-colors duration-300 shadow-md" href="#contact">
          Projekt anfragen
        </a>
        <a class="w-full sm:w-auto text-center border border-navy text-navy font-label-sm text-label-sm uppercase px-8 py-4 rounded hover:bg-surface-container transition-colors duration-300" href="#work">
          Cases ansehen
        </a>
      </div>
    </div>

    <!-- Right: Image & Badges -->
    <div class="md:col-span-5 relative mt-12 md:mt-0 flex justify-center">
      <div class="relative w-full max-w-sm rounded-xl overflow-hidden shadow-sm border border-border-subtle">
        <img
          src="/christian-roessler.jpg"
          alt="Christian Roessler Portrait"
          class="w-full h-auto object-cover aspect-[3/4]"
          width="600"
          height="800"
          loading="eager"
        />
        <!-- Floating Badges -->
        <div class="absolute bottom-6 left-[-1rem] bg-surface-card border border-border-subtle px-4 py-2 rounded shadow-lg flex items-center space-x-2 transform -rotate-2">
          <span class="material-symbols-outlined text-green-600 text-sm" style="font-variation-settings: 'FILL' 1;">check_circle</span>
          <span class="font-label-sm text-label-sm text-ink-text">Verfügbar ab Nov</span>
        </div>
        <div class="absolute top-12 right-[-1rem] bg-navy text-white px-4 py-2 rounded shadow-lg flex items-center space-x-2 transform rotate-3">
          <span class="material-symbols-outlined text-gold text-sm">bolt</span>
          <span class="font-label-sm text-label-sm">§42c EnWG Expert</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="w-full bg-navy text-white py-12 relative overflow-hidden">
    <div class="max-w-container-max mx-auto px-4 md:px-8 grid grid-cols-2 md:grid-cols-4 gap-8 divide-x divide-primary-fixed-dim/20 text-center relative z-10">
      <div class="flex flex-col items-center">
        <span class="font-headline-md text-headline-md font-bold mb-1">13<span class="text-gold">+</span></span>
        <span class="font-body-md text-body-md text-primary-fixed-dim uppercase tracking-wide text-xs">Jahre Erfahrung</span>
      </div>
      <div class="flex flex-col items-center">
        <span class="font-headline-md text-headline-md font-bold mb-1">§42c</span>
        <span class="font-body-md text-body-md text-primary-fixed-dim uppercase tracking-wide text-xs">EnWG Spezialist</span>
      </div>
      <div class="flex flex-col items-center">
        <span class="font-headline-md text-headline-md font-bold mb-1">5<span class="text-gold">+</span></span>
        <span class="font-body-md text-body-md text-primary-fixed-dim uppercase tracking-wide text-xs">Programmiersprachen</span>
      </div>
      <div class="flex flex-col items-center">
        <span class="font-headline-md text-headline-md font-bold mb-1">24<span class="text-gold">h</span></span>
        <span class="font-body-md text-body-md text-primary-fixed-dim uppercase tracking-wide text-xs">Antwortzeit</span>
      </div>
    </div>
  </section>

  <!-- Core Competencies -->
  <section class="max-w-container-max mx-auto px-4 md:px-8 py-16 md:py-stack-lg" id="expertise">
    <div class="mb-12 md:mb-16">
      <h2 class="font-headline-md md:font-headline-lg text-headline-md md:text-headline-lg text-ink-text mb-4">Core Competencies</h2>
      <p class="font-body-lg text-body-lg text-muted-text max-w-2xl">
        Präzise technische Umsetzung gepaart mit tiefem Branchenverständnis.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <!-- Card 1: Energie -->
      <div class="bg-surface-card border border-border-subtle p-8 rounded-xl hover:shadow-[0_10px_15px_-3px_rgba(30,58,138,0.1)] transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container rounded flex items-center justify-center mb-6 text-navy group-hover:bg-navy group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-2xl">bolt</span>
        </div>
        <h3 class="font-headline-md text-xl font-bold text-ink-text mb-3">Energiesoftware</h3>
        <p class="font-body-md text-muted-text mb-6">
          Spezialisiert auf die Entwicklung von Softwarelösungen für den Energiesektor, inklusive tiefer Expertise in regulatorischen Anforderungen wie §42c EnWG.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">Smart Metering</span>
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">API Integration</span>
        </div>
      </div>

      <!-- Card 2: Fullstack -->
      <div class="bg-surface-card border border-border-subtle p-8 rounded-xl hover:shadow-[0_10px_15px_-3px_rgba(30,58,138,0.1)] transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container rounded flex items-center justify-center mb-6 text-navy group-hover:bg-navy group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-2xl">code</span>
        </div>
        <h3 class="font-headline-md text-xl font-bold text-ink-text mb-3">Fullstack-Entwicklung</h3>
        <p class="font-body-md text-muted-text mb-6">
          Von skalierbaren Backend-Architekturen bis hin zu performanten Frontend-Applikationen. Moderne Tech-Stacks für zukunftssichere Produkte.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">Node.js / Python</span>
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">React / Vue</span>
        </div>
      </div>

      <!-- Card 3: KI -->
      <div class="bg-surface-card border border-border-subtle p-8 rounded-xl hover:shadow-[0_10px_15px_-3px_rgba(30,58,138,0.1)] transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container rounded flex items-center justify-center mb-6 text-navy group-hover:bg-navy group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-2xl">psychology</span>
        </div>
        <h3 class="font-headline-md text-xl font-bold text-ink-text mb-3">KI-Integration</h3>
        <p class="font-body-md text-muted-text mb-6">
          Nahtlose Einbindung von künstlicher Intelligenz und Machine Learning Modellen in bestehende Systeme zur Prozessautomatisierung.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">LLM APIs</span>
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">Agentic AI</span>
        </div>
      </div>

      <!-- Card 4: Web -->
      <div class="bg-surface-card border border-border-subtle p-8 rounded-xl hover:shadow-[0_10px_15px_-3px_rgba(30,58,138,0.1)] transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container rounded flex items-center justify-center mb-6 text-navy group-hover:bg-navy group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-2xl">web</span>
        </div>
        <h3 class="font-headline-md text-xl font-bold text-ink-text mb-3">Webdesign &amp; Websites</h3>
        <p class="font-body-md text-muted-text mb-6">
          Performance-optimierte, barrierefreie und ästhetisch anspruchsvolle Webpräsenzen, die Konversionen treiben und die Marke stärken.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">Astro / Next.js</span>
          <span class="bg-[#EFF6FF] text-navy font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">UI/UX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Select Works -->
  <section class="bg-surface-container-low border-y border-outline-variant py-16 md:py-stack-lg" id="work">
    <div class="max-w-container-max mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 md:mb-16">
        <div>
          <h2 class="font-headline-md md:font-headline-lg text-headline-md md:text-headline-lg text-ink-text mb-4">Select Works</h2>
          <p class="font-body-lg text-body-lg text-muted-text max-w-2xl">
            Komplexe Herausforderungen, elegant gelöst.
          </p>
        </div>
        <a class="inline-flex items-center space-x-2 text-navy font-label-sm uppercase tracking-wider mt-6 md:mt-0 hover:text-primary transition-colors" href="#">
          <span>Alle Projekte ansehen</span>
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <div class="space-y-8">
        <!-- Featured: KiezPower -->
        <div class="bg-navy text-white rounded-xl overflow-hidden flex flex-col md:flex-row border border-navy shadow-md">
          <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-between">
            <div>
              <span class="font-label-sm text-[11px] uppercase tracking-widest text-primary-fixed-dim mb-4 block">Energie / SaaS</span>
              <h3 class="font-headline-md text-2xl font-bold mb-4">KiezPower Management Dashboard</h3>
              <p class="font-body-md text-inverse-primary/80 mb-8 leading-relaxed">
                Vollständige Neuentwicklung einer B2B-Plattform zur Verwaltung lokaler Energiegemeinschaften unter strenger Einhaltung der §42c EnWG Richtlinien. Integration von Echtzeit-Smart-Meter-Daten.
              </p>
            </div>
            <div class="flex flex-wrap gap-2 mt-auto">
              <span class="bg-white/10 text-white border border-white/20 font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">React</span>
              <span class="bg-white/10 text-white border border-white/20 font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">Node.js</span>
              <span class="bg-white/10 text-white border border-white/20 font-label-sm text-[11px] uppercase px-3 py-1 rounded-full tracking-wide">PostgreSQL</span>
            </div>
          </div>
          <div class="md:w-1/2 bg-surface-container-high/10 min-h-[300px] flex items-center justify-center relative p-8">
            <div class="w-full h-full bg-white/5 border border-white/10 rounded-lg shadow-2xl backdrop-blur-sm p-4 flex flex-col space-y-4">
              <div class="h-8 w-1/3 bg-white/20 rounded"></div>
              <div class="flex space-x-4 h-24">
                <div class="w-1/3 bg-white/10 rounded"></div>
                <div class="w-1/3 bg-white/10 rounded"></div>
                <div class="w-1/3 bg-white/10 rounded"></div>
              </div>
              <div class="flex-grow bg-white/10 rounded mt-2"></div>
            </div>
          </div>
        </div>

        <!-- Secondary Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Project: Hauptversammlung -->
          <div class="bg-surface-card border border-border-subtle rounded-xl overflow-hidden hover:shadow-[0_10px_15px_-3px_rgba(30,58,138,0.1)] transition-all duration-300">
            <div class="h-48 bg-surface-variant p-6 flex items-end">
              <div class="w-full h-32 bg-white rounded-t-lg shadow-sm border border-border-subtle border-b-0 p-4">
                <div class="h-4 w-1/2 bg-surface-container rounded mb-4"></div>
                <div class="h-2 w-full bg-surface-container rounded mb-2"></div>
                <div class="h-2 w-3/4 bg-surface-container rounded"></div>
              </div>
            </div>
            <div class="p-8">
              <span class="font-label-sm text-[11px] uppercase tracking-widest text-muted-text mb-3 block">FinTech / Legal</span>
              <h3 class="font-headline-md text-xl font-bold text-ink-text mb-3">Hauptversammlungs-Software</h3>
              <p class="font-body-md text-muted-text mb-6 text-sm">
                Hochsicheres System für die Durchführung digitaler Aktionärsversammlungen mit Live-Voting und rechtssicherer Protokollierung.
              </p>
            </div>
          </div>

          <!-- Project: KI-Agentur -->
          <div class="bg-surface-card border border-border-subtle rounded-xl overflow-hidden hover:shadow-[0_10px_15px_-3px_rgba(30,58,138,0.1)] transition-all duration-300">
            <div class="h-48 bg-surface-container-highest p-6 flex items-center justify-center">
              <div class="w-24 h-24 rounded-full bg-white shadow-sm border border-border-subtle flex items-center justify-center">
                <span class="material-symbols-outlined text-4xl text-navy">smart_toy</span>
              </div>
            </div>
            <div class="p-8">
              <span class="font-label-sm text-[11px] uppercase tracking-widest text-muted-text mb-3 block">AI / Automation</span>
              <h3 class="font-headline-md text-xl font-bold text-ink-text mb-3">Autonome KI-Agentur</h3>
              <p class="font-body-md text-muted-text mb-6 text-sm">
                Entwicklung eines Netzwerks spezialisierter LLM-Agenten zur vollautomatischen Abwicklung von B2B-Support-Anfragen.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA / Contact -->
  <section class="relative py-24 md:py-32 overflow-hidden bg-surface" id="contact">
    <div class="absolute inset-0 bg-gradient-to-br from-surface-variant/40 to-surface-container/20 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary-fixed/20 to-transparent pointer-events-none blur-3xl"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-headline-lg-mobile md:font-headline-xl text-headline-lg-mobile md:text-headline-xl text-ink-text mb-6">
        Lassen Sie uns <br />über Ihr Projekt sprechen.
      </h2>
      <p class="font-body-lg text-body-lg text-muted-text mb-10 max-w-xl mx-auto">
        Egal ob kurzfristige Kapazitätsengpässe, komplexe Architektur-Entscheidungen oder langfristige Zusammenarbeit.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center space-y-4 sm:space-y-0 sm:space-x-6">
        <a class="w-full sm:w-auto bg-navy text-white font-label-sm text-label-sm uppercase px-10 py-4 rounded hover:bg-primary transition-colors duration-300 shadow-md" href="mailto:christian.roessler@cmdscale.com">
          E-Mail senden
        </a>
        <a class="w-full sm:w-auto bg-white border border-border-subtle text-ink-text font-label-sm text-label-sm uppercase px-10 py-4 rounded hover:bg-surface-container transition-colors duration-300 shadow-sm flex items-center justify-center space-x-2" href="#">
          <span class="material-symbols-outlined text-lg">calendar_month</span>
          <span>Termin buchen</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-surface-container-low dark:bg-tertiary border-t border-outline-variant dark:border-tertiary-container w-full transition-colors duration-300">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 py-12 max-w-container-max mx-auto w-full">
      <div class="font-headline-md text-headline-md text-on-surface dark:text-surface-bright mb-6 md:mb-0">
        Christian Roessler
      </div>
      <div class="flex flex-col items-center md:items-end text-center md:text-right space-y-4 md:space-y-2">
