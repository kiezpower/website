---
---

<section class="calculator" id="rechner">
  <div class="container">
    <span class="section-tag">Vorteilsrechner</span>
    <h2 class="section-title reveal">Was bringt dir KiezPower?</h2>
    <p class="section-sub reveal">
      Berechne deinen persönlichen Vorteil — ob du Strom produzierst oder verbrauchst.
    </p>

    <div class="calc-card reveal">

      <!-- Role toggle -->
      <div class="role-toggle" role="group" aria-label="Rolle wählen">
        <button class="role-btn active" data-role="produzent" type="button">
          ☀️ Ich habe eine PV-Anlage
        </button>
        <button class="role-btn" data-role="konsument" type="button">
          🏠 Ich suche günstigen Strom
        </button>
      </div>

      <!-- Slider -->
      <div class="slider-section">
        <div class="slider-label">
          <span id="slider-question">Wie viel Überschussstrom erzeugst du pro Jahr?</span>
          <strong><span id="kwh-display">1.500</span> kWh</strong>
        </div>
        <input
          type="range"
          id="kwh-slider"
          min="500"
          max="10000"
          step="100"
          value="1500"
          aria-label="Jährliche kWh"
        />
        <div class="slider-ticks">
          <span>500 kWh</span>
          <span>5.000 kWh</span>
          <span>10.000 kWh</span>
        </div>
      </div>

      <!-- Results -->
      <div class="results">
        <div class="result-row">
          <div class="result-card baseline">
            <div class="result-label" id="baseline-label">Ohne KiezPower</div>
            <div class="result-sub" id="baseline-sub">Einspeisevergütung · 8 ct/kWh</div>
            <div class="result-amount" id="baseline-amount">120 €</div>
            <div class="result-period">pro Jahr</div>
          </div>

          <div class="result-divider">
            <div class="result-arrow">→</div>
            <div class="result-badge" id="result-badge">+105 €/Jahr</div>
          </div>

          <div class="result-card highlight">
            <div class="result-label">Mit KiezPower</div>
            <div class="result-sub" id="kiezpower-sub">Kiez-Preis · ab 15 ct/kWh</div>
            <div class="result-amount" id="kiezpower-amount">225 €</div>
            <div class="result-period">pro Jahr</div>
          </div>
        </div>

        <p class="result-hint" id="result-hint">
          Produzenten verdienen im Schnitt <strong>87 % mehr</strong> als mit der gesetzlichen Einspeisevergütung.
        </p>
      </div>

    </div>

    <p class="calc-disclaimer">
      Richtwerte. Tatsächliche Ergebnisse hängen von deinem Wunschpreis, der lokalen Nachfrage und dem Matching ab.
    </p>
  </div>
</section>

<script>
  const RATES = {
    produzent: { market: 0.08, kiezpower: 0.15 },
    konsument: { market: 0.35, kiezpower: 0.20 },
  };

  const LABELS = {
    produzent: {
      question: 'Wie viel Überschussstrom erzeugst du pro Jahr?',
      baselineSub: 'Einspeisevergütung · 8 ct/kWh',
      kiezpowerSub: 'Kiez-Preis · ab 15 ct/kWh',
      hint: (pct) => `Produzenten verdienen im Schnitt <strong>${pct} % mehr</strong> als mit der gesetzlichen Einspeisevergütung.`,
    },
    konsument: {
      question: 'Wie viel Strom verbrauchst du pro Jahr?',
      baselineSub: 'Grundversorger · ~35 ct/kWh',
      kiezpowerSub: 'Kiez-Preis · bis 20 ct/kWh',
      hint: (pct) => `Konsumenten sparen im Schnitt <strong>${pct} % </strong> gegenüber dem Grundversorger.`,
    },
  };

  let role = 'produzent';

  const slider       = document.getElementById('kwh-slider');
  const kwhDisplay   = document.getElementById('kwh-display');
  const question     = document.getElementById('slider-question');
  const baselineAmt  = document.getElementById('baseline-amount');
  const baselineSub  = document.getElementById('baseline-sub');
  const kiezAmt      = document.getElementById('kiezpower-amount');
  const kiezSub      = document.getElementById('kiezpower-sub');
  const badge        = document.getElementById('result-badge');
  const hint         = document.getElementById('result-hint');

  function fmt(eur) {
    return new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(eur);
  }

  function update() {
    const kwh     = Number(slider.value);
    const rates   = RATES[role];
    const labels  = LABELS[role];

    const baseline  = kwh * rates.market;
    const kiez      = kwh * rates.kiezpower;
    const diff      = Math.abs(kiez - baseline);
    const pct       = Math.round((diff / baseline) * 100);

    kwhDisplay.textContent  = kwh.toLocaleString('de-DE');
    question.textContent    = labels.question;
    baselineSub.textContent = labels.baselineSub;
    kiezSub.textContent     = labels.kiezpowerSub;
    baselineAmt.textContent = fmt(baseline);
    kiezAmt.textContent     = fmt(kiez);

    if (role === 'produzent') {
      badge.textContent = `+${fmt(diff)}/Jahr`;
      badge.className   = 'result-badge positive';
    } else {
      badge.textContent = `−${fmt(diff)}/Jahr`;
      badge.className   = 'result-badge negative';
    }

    hint.innerHTML = labels.hint(pct);
  }

  slider.addEventListener('input', update);

  document.querySelectorAll('.role-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.role-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      role = btn.dataset.role;
      update();
    });
  });

  update();
</script>

<style>
  .calculator {
    padding: 6rem 2rem;
    background: var(--night);
    border-top: 1px solid var(--border);
  }

  .calc-card {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    max-width: 780px;
    margin-top: 3rem;
  }

  /* Role toggle */
  .role-toggle {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    background: var(--night);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.3rem;
  }

  .role-btn {
    flex: 1;
    padding: 0.65rem 1rem;
    border: none;
    border-radius: calc(var(--radius-md) - 2px);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .role-btn.active {
    background: var(--night-light);
    color: var(--white);
  }

  /* Slider */
  .slider-section {
    margin-bottom: 2.5rem;
  }

  .slider-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .slider-label span {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .slider-label strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--white);
    white-space: nowrap;
  }

  input[type="range"] {
    width: 100%;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: var(--night-light);
    outline: none;
    cursor: pointer;
  }

  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.4);
    cursor: pointer;
    transition: box-shadow 0.2s;
  }

  input[type="range"]::-webkit-slider-thumb:hover {
    box-shadow: 0 0 18px rgba(34, 197, 94, 0.6);
  }

  input[type="range"]::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--green);
    border: none;
    cursor: pointer;
  }

  .slider-ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    font-size: 0.72rem;
    color: var(--muted);
    opacity: 0.6;
  }

  /* Results */
  .result-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .result-card {
    flex: 1;
    background: var(--night);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-align: center;
  }

  .result-card.highlight {
    border-color: var(--green);
    box-shadow: 0 0 24px rgba(34, 197, 94, 0.12);
  }

  .result-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }

  .result-sub {
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .result-amount {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--white);
    line-height: 1;
  }

  .result-card.highlight .result-amount { color: var(--green); }

  .result-period {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.3rem;
  }

  .result-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .result-arrow {
    font-size: 1.2rem;
    color: var(--muted);
  }

  .result-badge {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .result-badge.positive {
    background: rgba(34, 197, 94, 0.15);
    color: var(--green);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .result-badge.negative {
    background: rgba(34, 197, 94, 0.15);
    color: var(--green);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .result-hint {
    margin-top: 1.25rem;
    font-size: 0.825rem;
    color: var(--muted);
    text-align: center;
    line-height: 1.6;
  }

  .result-hint strong { color: var(--white); }

  .calc-disclaimer {
    margin-top: 1.5rem;
    font-size: 0.72rem;
    color: var(--muted);
    opacity: 0.6;
    max-width: 780px;
  }

  @media (max-width: 600px) {
    .calc-card { padding: 1.5rem; }

    .role-toggle { flex-direction: column; }

    .result-row {
      flex-direction: column;
      gap: 0.75rem;
    }

    .result-divider { flex-direction: row; }

    .result-arrow { transform: rotate(90deg); }

    .slider-label { flex-direction: column; gap: 0.25rem; }
  }
</style>
