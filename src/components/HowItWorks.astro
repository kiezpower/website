---
const svg = (paths: string, size = 22) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;

const steps = [
  {
    num: '01',
    icon: svg('<path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>'),
    title: 'Community beitreten',
    desc:  'Melde dich an und wähle deine lokale Kiez-Community. Produzent mit PV-Anlage oder Konsument — beides ist willkommen.',
  },
  {
    num: '02',
    icon: svg('<path d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/>'),
    title: 'Smartmeter verbinden',
    desc:  'Verbinde deinen Smartmeter über unsere Bridge. KiezPower liest automatisch Verbrauch und Erzeugung in Echtzeit aus.',
  },
  {
    num: '03',
    icon: svg('<path d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/>'),
    title: 'Automatisches Matching',
    desc:  'Alle 15 Minuten werden Angebot und Nachfrage in deiner Community gematcht. Du handelst, ohne etwas tun zu müssen.',
  },
  {
    num: '04',
    icon: svg('<path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>'),
    title: 'Vertrag & Zahlung',
    desc:  'Jeder Handel wird mit einer rechtssicheren eIDAS-Signatur besiegelt. Zahlung und Abrechnung erfolgen automatisch über dein Wallet.',
  },
];
---

<section class="how" id="wie-es-funktioniert">
  <div class="container">
    <span class="section-tag reveal">So funktioniert's</span>
    <h2 class="section-title reveal">Energie teilen war<br />noch nie so einfach</h2>
    <p class="section-sub reveal">
      Kein Papierkram, keine Wartezeiten. KiezPower übernimmt das Matching,
      die Verträge und die Abrechnung — vollautomatisch.
    </p>

    <div class="how-flow">
      {steps.map((s, i) => (
        <div class="how-step reveal">
          <div class="how-step-badge">{s.num}</div>
          <div class="how-step-icon" set:html={s.icon} />
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how {
    background: var(--night-mid);
    padding: 6rem 2rem;
  }

  /* ── Horizontal flow ── */
  .how-flow {
    display: flex;
    gap: 0;
    margin-top: 3.5rem;
    position: relative;
  }

  /* Connector line through badge centres */
  .how-flow::before {
    content: '';
    position: absolute;
    top: 19px; /* half of 40px badge */
    left: calc(40px / 2);
    right: calc(40px / 2);
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(34, 197, 94, 0.25) 10%,
      rgba(34, 197, 94, 0.25) 90%,
      transparent
    );
  }

  .how-step {
    flex: 1;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .how-step-badge {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--night-mid);
    border: 1px solid rgba(34, 197, 94, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--green);
    letter-spacing: 0.05em;
    margin-bottom: 1.4rem;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .how-step-icon {
    color: var(--green);
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .how-step h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--white);
  }

  .how-step p {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ── Responsive: vertical on mobile ── */
  @media (max-width: 768px) {
    .how-flow {
      flex-direction: column;
      gap: 2rem;
    }

    .how-flow::before {
      top: 20px;
      bottom: 20px;
      left: 19px; /* half of 40px badge */
      right: auto;
      width: 1px;
      height: auto;
      background: linear-gradient(
        to bottom,
        transparent,
        rgba(34, 197, 94, 0.25) 10%,
        rgba(34, 197, 94, 0.25) 90%,
        transparent
      );
    }

    .how-step {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0 1.2rem;
      padding: 0;
      align-items: flex-start;
    }

    .how-step-badge {
      margin-bottom: 0;
    }

    .how-step-icon {
      order: -1;
      align-self: center;
      margin-bottom: 0;
    }

    .how-step h3,
    .how-step p {
      flex: 1 1 100%;
      margin-left: calc(40px + 1.2rem);
    }

    .how-step h3 {
      margin-top: 0.6rem;
    }
  }
</style>
