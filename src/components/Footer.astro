---
const links = [
  { href: '/fuer-netzbetreiber', label: 'Für Partner' },
  { href: '/partner',           label: 'Partner-Programm' },
  { href: '/referenzen',        label: 'Referenzen' },
  { href: '/agb',                label: 'AGB' },
  { href: '/datenschutz',        label: 'Datenschutz' },
  { href: '/impressum',          label: 'Impressum' },
  { href: '/faq',                label: 'FAQ' },
];
---

<footer>
  <a href="/" class="footer-logo" aria-label="KiezPower Startseite">
    <img src="/logo.png" alt="KiezPower Logo" width="28" height="28" class="footer-logo-img" />
    <span>KiezPower</span>
  </a>
  <nav class="footer-links" aria-label="Footer-Navigation">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </nav>
  <p class="footer-copy">© 2026 KiezPower · Lokal. Grün. Automatisch.</p>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    background: var(--night);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--white);
    text-decoration: none;
  }

  .footer-logo-img {
    object-fit: contain;
    filter: drop-shadow(0 0 6px rgba(34, 197, 94, 0.4));
  }

  .footer-logo:hover .footer-logo-img {
    filter: drop-shadow(0 0 10px rgba(34, 197, 94, 0.7));
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--white); }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    footer { flex-direction: column; text-align: center; }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
