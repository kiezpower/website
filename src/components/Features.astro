---
const svg = (paths: string, size = 22) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;

const features = [
  {
    icon: svg('<path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>'),
    title: 'Echtzeit-Dashboard',
    desc:  'Sieh in Echtzeit, wie viel Energie deine Community erzeugt, verbraucht und handelt — auf die Minute genau.',
    badge: 'Live SSE-Updates',
    primary: true,
  },
  {
    icon: svg('<path d="M14.25 7.756a4.5 4.5 0 100 8.488M7.5 10.5h5.25m-5.25 3h5.25M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'),
    title: 'Transparente Preise',
    desc:  'Produzent und Konsument vereinbaren den Energiepreis direkt — KiezPower matched automatisch. Einzige Gebühr: 1,5 % Plattformgebühr. Netzentgelte werden separat vom Netzbetreiber abgerechnet.',
    badge: 'SMARD-Integration',
    primary: false,
  },
  {
    icon: svg('<path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>'),
    title: 'Rechtssichere Verträge',
    desc:  'Jeder Handel wird mit einer fortgeschrittenen elektronischen Signatur nach eIDAS-VO abgesichert — vollautomatisch.',
    badge: 'eIDAS-konform',
    primary: false,
  },
  {
    icon: svg('<path d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/>'),
    title: 'Smartmeter-Anbindung',
    desc:  'Unterstützt SML/IR-Protokolle und verschiedene Netzbetreiber-Adapter. Plug & Play für die meisten modernen Zähler.',
    badge: 'SML · IR · Bridge',
    primary: false,
  },
  {
    icon: svg('<path d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3"/>'),
    title: 'Integriertes Wallet',
    desc:  'Dein Guthaben, deine Auszahlungen, deine Trades — alles in einem transparenten Ledger. Aufladung per Banküberweisung.',
    badge: 'Ledger-First',
    primary: false,
  },
  {
    icon: svg('<path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>', 28),
    title: 'DSGVO & § 42c EnWG',
    desc:  'KiezPower agiert als IT-Service-Provider — ohne Bilanzkreisverantwortung. Alle Daten bleiben in Deutschland.',
    badge: 'Made in Germany',
    primary: false,
    compliance: true,
  },
];
---

<section class="features" id="features">
  <div class="container">
    <span class="section-tag reveal">Plattform</span>
    <h2 class="section-title reveal">Alles drin, was du brauchst</h2>
    <p class="section-sub reveal">
      KiezPower ist mehr als ein Marktplatz — es ist eine vollständige
      Infrastruktur für lokale Energiegemeinschaften.
    </p>

    <div class="features-grid">
      {features.map((f) => (
        <div class:list={['feature-card', 'reveal', { primary: f.primary, compliance: f.compliance }]}>
          <div class="feature-icon" set:html={f.icon} />
          <div class="feature-body">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
          <span class="feature-badge">{f.badge}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 6rem 2rem;
    background: var(--night);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3.5rem;
  }

  .feature-card {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease-out, transform 200ms var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .feature-card:hover {
      border-color: rgba(34, 197, 94, 0.3);
      transform: translateY(-3px);
    }
  }

  /* ── Hero card (spans 2 cols) ── */
  .feature-card.primary {
    grid-column: span 2;
    background: linear-gradient(135deg, var(--night-mid) 0%, rgba(34, 197, 94, 0.04) 100%);
    border-color: rgba(34, 197, 94, 0.18);
  }

  .feature-card.primary h3 {
    font-size: 1.15rem;
  }

  .feature-card.primary p {
    font-size: 0.9rem;
  }

  /* ── Compliance banner (spans all 3 cols) ── */
  .feature-card.compliance {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: center;
    gap: 2rem;
    background: var(--night-light);
    border-color: rgba(148, 163, 184, 0.18);
  }

  @media (hover: hover) and (pointer: fine) {
    .feature-card.compliance:hover {
      transform: none;
      border-color: rgba(34, 197, 94, 0.2);
    }
  }

  .feature-card.compliance .feature-body {
    flex: 1;
  }

  .feature-card.compliance .feature-badge {
    margin-top: 0;
    flex-shrink: 0;
  }

  /* ── Icon container ── */
  .feature-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--green-glow);
    border: 1px solid rgba(34, 197, 94, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    margin-bottom: 1.2rem;
    flex-shrink: 0;
  }

  .feature-card.compliance .feature-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    margin-bottom: 0;
  }

  /* ── Text ── */
  .feature-body {
    flex: 1;
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--white);
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .feature-badge {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
    background: var(--green-glow);
    border: 1px solid rgba(34, 197, 94, 0.2);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .feature-card.primary {
      grid-column: span 2;
    }

    .feature-card.compliance {
      flex-direction: column;
      align-items: flex-start;
    }

    .feature-card.compliance .feature-icon {
      margin-bottom: 1.2rem;
    }

    .feature-card.compliance .feature-badge {
      margin-top: 1rem;
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .feature-card.primary {
      grid-column: span 1;
    }
  }
</style>
