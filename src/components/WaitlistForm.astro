---
---

<section class="waitlist" id="warteliste">
  <div class="container">
    <div class="waitlist-inner">

      <!-- Left: copy -->
      <div class="waitlist-copy">
        <span class="section-tag">Warteliste</span>
        <h2 class="section-title">
          KiezPower kommt<br />in deinen Kiez.
        </h2>
        <p class="section-sub">
          Trag dich ein — wir benachrichtigen dich, sobald deine PLZ
          verfügbar ist. Je mehr Nachbarn mitmachen, desto schneller geht's los.
        </p>

        <div class="waitlist-perks">
          <div class="perk">
            <span class="perk-icon">⚡</span>
            <div>
              <strong>Früher Zugang</strong>
              <p>Wartelisten-Mitglieder erhalten bevorzugten Zugang beim Launch.</p>
            </div>
          </div>
          <div class="perk">
            <span class="perk-icon">📍</span>
            <div>
              <strong>PLZ-basiertes Rollout</strong>
              <p>Wir starten dort, wo die Nachfrage am größten ist.</p>
            </div>
          </div>
          <div class="perk">
            <span class="perk-icon">🔒</span>
            <div>
              <strong>Kein Spam</strong>
              <p>Nur eine E-Mail wenn's losgeht. Versprochen.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form card -->
      <div class="waitlist-card">
        <div class="card-header">
          <div class="card-live-dot" aria-hidden="true"></div>
          <span>Jetzt Platz sichern</span>
        </div>

        <form id="waitlist-form" novalidate>
          <div class="field">
            <label for="wl-email">E-Mail-Adresse</label>
            <input
              id="wl-email"
              name="email"
              type="email"
              placeholder="du@beispiel.de"
              autocomplete="email"
              required
            />
            <span class="field-error" id="err-email"></span>
          </div>

          <div class="field">
            <label for="wl-plz">Postleitzahl</label>
            <input
              id="wl-plz"
              name="plz"
              type="text"
              inputmode="numeric"
              pattern="\d{5}"
              maxlength="5"
              placeholder="10115"
              autocomplete="postal-code"
              required
            />
            <span class="field-error" id="err-plz"></span>
          </div>

          <div class="field">
            <label>Ich bin …</label>
            <div class="role-group" role="radiogroup" aria-label="Rolle wählen">
              <label class="role-option">
                <input type="radio" name="role" value="Konsument" checked />
                <span class="role-btn">
                  <span class="role-icon">🏠</span>
                  <span class="role-label">Konsument</span>
                  <span class="role-sub">Günstig Strom kaufen</span>
                </span>
              </label>
              <label class="role-option">
                <input type="radio" name="role" value="Produzent" />
                <span class="role-btn">
                  <span class="role-icon">☀️</span>
                  <span class="role-label">Produzent</span>
                  <span class="role-sub">PV-Anlage vorhanden</span>
                </span>
              </label>
              <label class="role-option">
                <input type="radio" name="role" value="Beides" />
                <span class="role-btn">
                  <span class="role-icon">⚡</span>
                  <span class="role-label">Beides</span>
                  <span class="role-sub">Produzent & Konsument</span>
                </span>
              </label>
            </div>
          </div>

          <button type="submit" class="submit-btn">
            Platz auf Warteliste sichern →
          </button>

          <p class="form-hint" id="form-hint">
            Kostenlos &amp; unverbindlich. Abmeldung jederzeit möglich.
          </p>
          <p class="form-error" id="form-error" hidden></p>
        </form>

        <!-- Success state -->
        <div class="success-state" id="success-state" hidden>
          <div class="success-icon">✓</div>
          <h3>Du bist dabei!</h3>
          <p>Wir melden uns, sobald KiezPower in deiner PLZ startet.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .waitlist {
    padding: 6rem 2rem;
    background: var(--night);
    border-top: 1px solid var(--border);
  }

  .waitlist-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .waitlist-perks {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-top: 2rem;
  }

  .perk { display: flex; align-items: flex-start; gap: 1rem; }
  .perk-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 2px; }
  .perk strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }
  .perk p { font-size: 0.825rem; color: var(--muted); line-height: 1.5; margin: 0; }

  .waitlist-card {
    background: var(--night-mid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .card-header {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.8rem; font-weight: 600;
    color: var(--muted); margin-bottom: 1.8rem;
    text-transform: uppercase; letter-spacing: 0.1em;
  }

  .card-live-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--green);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
  }

  .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.2rem; }

  .field label {
    font-size: 0.8rem; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  .field input[type="email"],
  .field input[type="text"] {
    background: var(--night);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    width: 100%;
  }
  .field input::placeholder { color: rgba(148, 163, 184, 0.4); }
  .field input:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
  }
  .field input.error {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12);
  }

  .field-error { font-size: 0.75rem; color: #ef4444; min-height: 1rem; display: block; }

  .role-group {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;
  }
  .role-option input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
  .role-btn {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.75rem 0.5rem;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    cursor: pointer; text-align: center; background: var(--night);
    transition: border-color 150ms ease-out, background 150ms ease-out;
  }
  .role-option input:checked + .role-btn {
    border-color: var(--green); background: rgba(34, 197, 94, 0.08);
  }
  @media (hover: hover) and (pointer: fine) {
    .role-option:hover .role-btn { border-color: rgba(34, 197, 94, 0.4); }
  }
  .role-icon { font-size: 1.2rem; }
  .role-label { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; }
  .role-sub { font-size: 0.65rem; color: var(--muted); line-height: 1.3; }

  .submit-btn {
    width: 100%; background: var(--green); color: var(--night);
    border: none; border-radius: var(--radius-sm);
    padding: 0.9rem 1.5rem;
    font-family: var(--font-display); font-weight: 700; font-size: 0.95rem;
    cursor: pointer;
    transition: background 200ms ease-out, transform 160ms ease-out, box-shadow 200ms ease-out;
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.25);
    margin-bottom: 0.8rem;
  }
  @media (hover: hover) and (pointer: fine) {
    .submit-btn:hover {
      background: var(--green-dim);
      transform: translateY(-1px);
      box-shadow: 0 4px 24px rgba(34, 197, 94, 0.35);
    }
  }
  .submit-btn:active {
    transform: scale(0.97);
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.2);
  }

  .form-hint  { font-size: 0.72rem; color: var(--muted); text-align: center; line-height: 1.5; }
  .form-error { font-size: 0.8rem; color: #ef4444; text-align: center; line-height: 1.5; margin-top: 0.5rem; }
  .form-error[hidden] { display: none; }

  /* Success */
  .success-state[hidden] { display: none; }
  .success-state { text-align: center; padding: 1.5rem 0; }
  .success-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: rgba(34, 197, 94, 0.12); border: 2px solid var(--green);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; color: var(--green); font-weight: 700;
    margin: 0 auto 1.2rem;
    animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes pop-in {
    from { transform: scale(0.92); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }
  .success-state h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; }
  .success-state p  { color: var(--muted); font-size: 0.875rem; line-height: 1.6; }

  @media (max-width: 900px) { .waitlist-inner { grid-template-columns: 1fr; gap: 3rem; } }
  @media (max-width: 480px)  { .role-group { grid-template-columns: 1fr; } }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const supabase   = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const form       = document.getElementById('waitlist-form');
  const successEl  = document.getElementById('success-state');
  const submitBtn  = form.querySelector('button[type="submit"]');
  const formError  = document.getElementById('form-error');
  const emailInput = document.getElementById('wl-email');
  const plzInput   = document.getElementById('wl-plz');
  const errEmail   = document.getElementById('err-email');
  const errPlz     = document.getElementById('err-plz');

  function validateEmail(v) {
    if (!v) return 'E-Mail ist erforderlich.';
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'Bitte gültige E-Mail eingeben.';
    return '';
  }
  function validatePlz(v) {
    if (!v) return 'PLZ ist erforderlich.';
    if (!/^\d{5}$/.test(v)) return 'Bitte 5-stellige PLZ eingeben.';
    return '';
  }

  emailInput.addEventListener('blur', () => {
    const err = validateEmail(emailInput.value);
    errEmail.textContent = err;
    emailInput.classList.toggle('error', !!err);
  });

  plzInput.addEventListener('input', () => {
    plzInput.value = plzInput.value.replace(/\D/g, '');
  });
  plzInput.addEventListener('blur', () => {
    const err = validatePlz(plzInput.value);
    errPlz.textContent = err;
    plzInput.classList.toggle('error', !!err);
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailErr = validateEmail(emailInput.value);
    const plzErr   = validatePlz(plzInput.value);
    errEmail.textContent = emailErr;
    errPlz.textContent   = plzErr;
    emailInput.classList.toggle('error', !!emailErr);
    plzInput.classList.toggle('error',   !!plzErr);
    if (emailErr || plzErr) return;

    const email = emailInput.value.trim();
    const plz   = plzInput.value.trim();
    const role  = form.querySelector('input[name="role"]:checked')?.value ?? 'Konsument';

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gespeichert …';
    formError.hidden = true;

    const { error } = await supabase
      .from('waitlist')
      .insert({ email, plz, role });

    if (error) {
      formError.textContent = error.code === '23505'
        ? 'Diese E-Mail ist bereits auf der Warteliste.'
        : 'Ein Fehler ist aufgetreten. Bitte versuche es später noch einmal.';
      formError.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Platz auf Warteliste sichern →';
      return;
    }

    form.hidden = true;
    successEl.hidden = false;
  });
</script>
