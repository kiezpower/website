<section class="cta-section" id="community">
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="cta-content">
    <h2>Dein Kiez, deine Energie.</h2>
    <p>
      Werde Teil der ersten lokalen Energie-Community in deiner Nachbarschaft.
      Kostenlos anmelden, Community wählen, Strom teilen.
    </p>
    <a href="#warteliste" class="btn-primary">Platz sichern →</a>
  </div>
</section>

<style>
  .cta-section {
    text-align: center;
    padding: 7rem 2rem;
    background: var(--night-mid);
    position: relative;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 50% 60% at 50% 100%, rgba(34, 197, 94, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    max-width: 580px;
    margin: 0 auto 1rem;
    line-height: 1.12;
  }

  p {
    color: var(--muted);
    max-width: 420px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
</style>
