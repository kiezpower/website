---
const plans = [
  {
    role: '☀️ Produzent',
    amount: '20¢',
    unit: '/ kWh',
    note: 'Basis ± 5 % Marktanpassung',
    featured: false,
    features: [
      'Mehr als die Einspeisevergütung',
      'Automatisches Sell-Matching',
      'Volumenrabatt ab 50 kWh/Monat',
      'Echtzeit-Statistiken',
      'Auszahlung aufs Konto',
    ],
  },
  {
    role: '🏠 Konsument',
    amount: '20¢',
    unit: '/ kWh',
    note: '+ 1,5 % Plattformgebühr',
    featured: true,
    features: [
      'Günstiger als Grundversorger',
      'Grüner Kiez-Strom',
      'Automatisches Buy-Matching',
      'Transparente Abrechnung',
      'Keine Mindestlaufzeit',
    ],
  },
];

const compliance = [
  { label: '§ 42c EnWG', desc: 'IT-Service-Provider Modell' },
  { label: 'eIDAS-VO',   desc: 'Fortgeschrittene E-Signatur' },
  { label: 'DSGVO',      desc: 'Daten in Deutschland' },
  { label: 'EnWG 2026',  desc: 'Vollständige Compliance' },
];
---

<section class="pricing" id="preise">
  <div class="container">
    <span class="section-tag reveal">Preismodell</span>
    <h2 class="section-title reveal">Fair für alle Seiten</h2>
    <p class="section-sub reveal">
      Egal ob du Strom produzierst oder verbrauchst — KiezPower ist günstiger
      als der Grundversorger und fairer als der Markt.
    </p>

    <div class="pricing-grid reveal">
      {plans.map((plan) => (
        <div class:list={['price-card', { featured: plan.featured }]}>
          {plan.featured && <div class="price-badge">Empfohlen</div>}
          <div class="price-role">{plan.role}</div>
          <div class="price-amount">
            {plan.amount} <span>{plan.unit}</span>
          </div>
          <div class="price-note">{plan.note}</div>
          <hr class="price-divider" />
          <ul class="price-features">
            {plan.features.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      ))}
    </div>

    <!-- Compliance strip -->
    <div class="compliance-strip reveal">
      {compliance.map((c) => (
        <div class="compliance-item">
          <div class="compliance-dot" aria-hidden="true"></div>
          <div><strong>{c.label}</strong> — {c.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing {
    background: var(--night-mid);
    padding: 6rem 2rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3.5rem;
    max-width: 780px;
  }

  .price-card {
    background: var(--night);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    position: relative;
  }

  .price-card.featured {
    border-color: var(--green);
    box-shadow: 0 0 40px rgba(34, 197, 94, 0.15);
  }

  .price-badge {
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%);
    background: var(--green);
    color: var(--night);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.9rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .price-role {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.3rem;
    line-height: 1;
  }

  .price-amount span {
    font-size: 1rem;
    font-weight: 400;
    color: var(--muted);
  }

  .price-note {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .price-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .price-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .price-features li {
    font-size: 0.875rem;
    color: var(--muted);
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .price-features li::before {
    content: '✓';
    color: var(--green);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Compliance strip */
  .compliance-strip {
    background: var(--night-light);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.8rem 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .compliance-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .compliance-item strong { color: var(--white); font-weight: 600; }

  .compliance-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
  }
</style>
