---
import P2PAnimation from './P2PAnimation.astro';

const stats = [
  { num: 'ab 13¢', label: 'pro kWh — du setzt den Preis' },
  { num: '15min', label: 'Matching-Intervall' },
  { num: '100%',  label: 'Lokal & automatisch' },
];
---

<section class="hero">
  <div class="hero-eyebrow">Peer-to-Peer Energie · Deutschland</div>

  <h1>Verkauf deinen Strom.<br /><em>Verschenke ihn nicht.</em></h1>

  <p>
    KiezPower handelt deinen Überschussstrom lokal — zu fairen Preisen, vollautomatisch.
  </p>

  <div class="hero-actions">
    <a href="#warteliste" class="btn-primary">Platz sichern →</a>
    <a href="#wie-es-funktioniert" class="btn-ghost">Wie funktioniert's?</a>
  </div>

  <P2PAnimation />

  <div class="stats" role="list">
    {stats.map((s) => (
      <div class="stat" role="listitem">
        <div class="stat-num">{s.num}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 7rem 2rem 4rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  /* Grid background */
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(34, 197, 94, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 197, 94, 0.06) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 100%);
    pointer-events: none;
  }

  /* Radial glow */
  .hero::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(34, 197, 94, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    flex: 1;
    max-width: 40px;
    height: 1px;
    background: var(--green);
    opacity: 0.5;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 5.2rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.03em;
    max-width: 780px;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--green) 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  p {
    font-size: 1.125rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 1;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  /* Stats bar */
  .stats {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 700px;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .stat {
    flex: 1;
    padding: 1.8rem 2rem;
    border-right: 1px solid var(--border);
    text-align: center;
  }

  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--green);
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .stats { flex-direction: column; }
    .stat { border-right: none; border-bottom: 1px solid var(--border); }
    .stat:last-child { border-bottom: none; }
  }
</style>
