---
import P2PAnimation from './P2PAnimation.astro';

const stats = [
  { num: '1,5 %',  label: 'Plattformgebühr — alles andere gehört dir' },
  { num: '15min',  label: 'Matching-Intervall' },
  { num: '100 %',  label: 'Lokal & transparent' },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow">Peer-to-Peer Energie · § 42c EnWG</div>

      <h1>Verkauf deinen Strom.<br /><em>Verschenke ihn nicht.</em></h1>

      <p>
        KiezPower vernetzt Solarstrom-Produzenten direkt mit Nachbarn — lokal,
        transparent und vollautomatisch.
      </p>

      <div class="hero-actions">
        <a href="#warteliste" class="btn-primary">Platz sichern →</a>
        <a href="#wie-es-funktioniert" class="btn-ghost">Wie funktioniert's?</a>
      </div>
    </div>

    <div class="hero-visual">
      <P2PAnimation />
    </div>
  </div>

  <div class="stats" role="list">
    {stats.map((s) => (
      <div class="stat" role="listitem">
        <div class="stat-num">{s.num}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding-top: 5rem;
    position: relative;
    overflow: hidden;
    background-image:
      linear-gradient(rgba(34, 197, 94, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 197, 94, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .hero::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 55% at 50% 35%, rgba(34, 197, 94, 0.09) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Split grid ── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 1.5rem;
    width: 100%;
    position: relative;
    z-index: 1;
    flex: 1;
  }

  .hero-content {
    text-align: left;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: hero-in 0.65s var(--ease-out) 0.25s both;
  }

  /* Suppress P2PAnimation's own top margin */
  .hero-visual :global(.p2p-visual) {
    margin-top: 0;
  }

  /* ── Text elements ── */
  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    animation: hero-in 0.55s var(--ease-out) 0.05s both;
  }

  .hero-eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--green);
    opacity: 0.5;
    flex-shrink: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 4.0rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    animation: hero-in 0.55s var(--ease-out) 0.2s both;
  }

  h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--green) 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-content > p {
    font-size: 1.0625rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 2.5rem;
    animation: hero-in 0.55s var(--ease-out) 0.35s both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: hero-in 0.55s var(--ease-out) 0.5s both;
  }

  /* ── Stats bar ── */
  .stats {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
    padding: 0 2rem;
    animation: hero-in 0.55s var(--ease-out) 0.65s both;
  }

  .stat {
    flex: 1;
    padding: 1.5rem 1.5rem;
    border-right: 1px solid var(--border);
    text-align: center;
  }

  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--white);
    line-height: 1;
    margin-bottom: 0.35rem;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.4;
  }

  /* ── Entrance animation ── */
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, h1, .hero-content > p,
    .hero-actions, .hero-visual, .stats {
      animation: none;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content {
      text-align: center;
      order: 2;
    }
    .hero-content > p {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-eyebrow { justify-content: center; }
    .hero-actions { justify-content: center; }
    .hero-visual  { order: 1; }
  }

  @media (max-width: 640px) {
    .stats {
      flex-direction: column;
      padding: 0;
    }
    .stat {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1.2rem 1.5rem;
    }
    .stat:last-child { border-bottom: none; }
  }
</style>
